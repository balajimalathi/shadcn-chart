{
  "name": "shadcn-chart-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "build": "npm run build:all",
    "build:all": "npm run typecheck && npm run build:pie-legend && npm run build:pie-donut && npm run build:radial-stacked && npm run build:line-interactive && npm run build:bar-interactive && npm run build:bar-multiple && npm run build:area-interactive",
    "build:pie-legend": "cross-env CHART=pie-legend vite build --config vite.chart.config.ts",
    "build:pie-donut": "cross-env CHART=pie-donut vite build --config vite.chart.config.ts",
    "build:radial-stacked": "cross-env CHART=radial-stacked vite build --config vite.chart.config.ts",
    "build:line-interactive": "cross-env CHART=line-interactive vite build --config vite.chart.config.ts",
    "build:bar-interactive": "cross-env CHART=bar-interactive vite build --config vite.chart.config.ts",
    "build:bar-multiple": "cross-env CHART=bar-multiple vite build --config vite.chart.config.ts",
    "build:area-interactive": "cross-env CHART=area-interactive vite build --config vite.chart.config.ts",
    "copy:assets": "node scripts/copy-assets.mjs",
    "build:package-assets": "npm run build:all && npm run copy:assets"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.2",
    "@tailwindcss/vite": "^4.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.503.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "tw-animate-css": "^1.2.8",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vite-plugin-singlefile": "^2.2.0"
  }
}
